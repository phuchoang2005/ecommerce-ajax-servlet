<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <!-- ========================= -->
    <!-- Request Tracing Filter    -->
    <!-- ========================= -->
    <filter>
        <filter-name>RequestTracingFilter</filter-name>
        <filter-class>org.personal_project.ecommerce.filter.RequestTracingFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>RequestTracingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>


    <!-- ========================= -->
    <!-- Global CORS Filter        -->
    <!-- ========================= -->
    <filter>
        <filter-name>GlobalFilter</filter-name>
        <filter-class>org.personal_project.ecommerce.filter.GlobalFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>GlobalFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>


    <!-- ========================= -->
    <!-- Global Exception Filter   -->
    <!-- ========================= -->
    <filter>
        <filter-name>GlobalExceptionFilter</filter-name>
        <filter-class>org.personal_project.ecommerce.filter.GlobalExceptionFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>GlobalExceptionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>


    <!-- ========================= -->
    <!-- Authentication Filter     -->
    <!-- ========================= -->
    <filter>
        <filter-name>AuthenticationFilter</filter-name>
        <filter-class>org.personal_project.ecommerce.filter.AuthenticationFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>AuthenticationFilter</filter-name>
        <url-pattern>/payment</url-pattern>
    </filter-mapping>


    <!-- ========================= -->
    <!-- Transaction Filter        -->
    <!-- ========================= -->
    <filter>
        <filter-name>TransactionFilter</filter-name>
        <filter-class>org.personal_project.ecommerce.filter.TransactionFilter</filter-class>
    </filter>

    <filter-mapping>
        <filter-name>TransactionFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>
    
</web-app>